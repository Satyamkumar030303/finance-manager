# Server
PORT=5000
NODE_ENV=development

# Database
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/finance_manager?retryWrites=true&w=majority

# Auth — use a strong 64+ character random string in production
JWT_SECRET=CHANGE_THIS_TO_A_STRONG_RANDOM_SECRET_AT_LEAST_64_CHARS
JWT_EXPIRE=15m

# Client
CLIENT_URL=http://localhost:5173

# Logging
LOG_LEVEL=info

# AI Provider — "claude" or "openai"
AI_PROVIDER=claude
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-key-here

# Redis (Phase 6)
REDIS_URL=redis://localhost:6379

# Currency Exchange Rates (Phase 5)
EXCHANGE_RATES_API_KEY=your-open-exchange-rates-key

# Stripe (Phase 8)
STRIPE_SECRET_KEY=sk_test_your-stripe-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Razorpay (Phase 8 — India)
RAZORPAY_KEY_ID=rzp_test_your-key
RAZORPAY_KEY_SECRET=your-secret
